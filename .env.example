# URL base do sistema (não alterar em ambiente padrão)
BASE_URL=https://www.automationpratice.com.br

# Credenciais de um usuário já cadastrado no site
# Cadastre em: https://www.automationpratice.com.br/register
TEST_USER_EMAIL=seu_email@exemplo.com
TEST_USER_PASSWORD=SuaSenha@123
